---
/**
 * ContactIcons — circular icon row for direct contact.
 * Channels: Telegram, WhatsApp, Instagram, Phone.
 * Palette-integrated: soft neutral fills, muted plum icons.
 */
import type { Lang } from '../i18n/utils';
import { PHONE_TEL } from '../i18n/utils';

interface Props {
  lang: Lang;
  size?: 'default' | 'large';
}

const { lang, size = 'default' } = Astro.props;

const channels = [
  {
    id: 'telegram',
    href: 'https://t.me/Anastassia_Nikolskaya',
    label: 'Telegram',
    external: true,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 2.77-2.95 15.08c-.19.95-.74 1.2-1.51.74l-4.18-3.08-2.02 1.94c-.22.22-.41.41-.84.41l.3-4.27 7.79-7.04c.34-.3-.07-.47-.53-.17L7.39 13.4l-4.14-1.29c-.9-.28-.91-.9.19-1.34l16.19-6.24c.75-.28 1.4.17 1.15 1.34z" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    id: 'whatsapp',
    href: 'https://wa.me/79270101378',
    label: 'WhatsApp',
    external: true,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>`,
  },
  {
    id: 'instagram',
    href: 'https://instagram.com/nasstena163',
    label: 'Instagram',
    external: true,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`,
  },
  {
    id: 'phone',
    href: PHONE_TEL,
    label: lang === 'ru' ? 'Телефон' : 'Phone',
    external: false,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  },
];

const circleSize = size === 'large' ? 'w-14 h-14' : 'w-12 h-12';
const iconSize = size === 'large' ? 'w-6 h-6' : 'w-5 h-5';
---

<div class="flex items-center gap-3">
  {channels.map(ch => (
    <a
      href={ch.href}
      target={ch.external ? '_blank' : undefined}
      rel={ch.external ? 'noopener' : undefined}
      aria-label={ch.label}
      class:list={[
        circleSize,
        'inline-flex items-center justify-center rounded-full',
        'bg-[var(--color-bg-cream)] border border-[var(--color-border)]',
        'text-[var(--color-primary)] hover:bg-[var(--color-secondary)] hover:text-[var(--color-primary-dark)] hover:border-[var(--color-secondary)]',
        'transition-all duration-200 no-underline shrink-0',
      ]}
    >
      <span class:list={[iconSize]} set:html={ch.icon} />
    </a>
  ))}
</div>
