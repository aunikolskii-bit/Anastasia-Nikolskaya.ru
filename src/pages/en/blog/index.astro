---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import BookingCta from '../../../components/BookingCta.astro';
import { getCollection } from 'astro:content';

const lang = 'en';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout
  lang={lang}
  title="Blog — Anastasia Nikolskaya"
  description="Articles about training during pregnancy and after childbirth in Samara."
  canonicalPath="/en/blog/"
  alternatePath="/ru/blog/"
>
  <Breadcrumb lang={lang} items={[{ label: 'Blog' }]} />

  <section class="bg-white">
    <div class="container section">
      <p class="label-uppercase mb-4">Blog</p>
      <h1>Articles</h1>

      {posts.length === 0 ? (
        <p class="mt-8 text-[var(--color-text-body)]">Articles coming soon.</p>
      ) : (
        <div class="mt-10 grid gap-8 sm:grid-cols-2">
          {posts.map((post) => (
            <a href={`/en/blog/${post.slug.replace('en/', '')}/`} class="card block hover:shadow-md transition-shadow no-underline group">
              <p class="text-xs text-[var(--color-text-body)] mb-2">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <h2 class="text-lg font-bold text-[var(--color-dark)] group-hover:text-[var(--color-primary)] transition-colors mb-2">
                {post.data.title}
              </h2>
              <p class="text-sm text-[var(--color-text-body)]">{post.data.description}</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="bg-[var(--color-bg-cream)]">
    <div class="container py-12 text-center">
      <BookingCta lang={lang} label="Book an intro session" />
    </div>
  </section>
</PageLayout>
