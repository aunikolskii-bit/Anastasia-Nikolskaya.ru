---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { YCLIENTS_URL } from '../i18n/utils';
import '../styles/global.css';

const lang = 'ru';
---

<BaseLayout
  lang={lang}
  title="404 — Страница не найдена"
  description="Страница не найдена."
  canonicalPath="/404/"
  alternatePath="/404/"
>
  <Header lang={lang} />
  <main id="main-content">
    <section class="bg-white">
      <div class="container section text-center">
        <div class="max-w-xl mx-auto">

          <!-- Russian -->
          <div class="mb-16">
            <p class="text-6xl font-bold text-[var(--color-primary-dark)] mb-4">404</p>
            <h1 class="text-2xl md:text-3xl mb-4">Страница не найдена</h1>
            <p class="text-[var(--color-text-body)] mb-8">
              Возможно, страница была перемещена или удалена. Попробуйте начать сначала.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/ru/" class="btn btn-primary">На главную</a>
              <a href={YCLIENTS_URL} target="_blank" rel="noopener" class="btn btn-secondary">Записаться</a>
              <a href="/ru/kontakty/" class="btn btn-secondary">Контакты</a>
            </div>
          </div>

          <!-- English -->
          <div class="border-t border-[var(--color-border)] pt-12">
            <h2 class="text-2xl md:text-3xl mb-4">Page not found</h2>
            <p class="text-[var(--color-text-body)] mb-8">
              This page may have been moved or removed. Try starting from the homepage.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/en/" class="btn btn-primary">Homepage</a>
              <a href={YCLIENTS_URL} target="_blank" rel="noopener" class="btn btn-secondary">Book now</a>
              <a href="/en/contact/" class="btn btn-secondary">Contact</a>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
