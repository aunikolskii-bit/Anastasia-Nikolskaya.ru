---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BookingCta from '../../components/BookingCta.astro';
import { SITE_URL } from '../../i18n/utils';

const lang = 'ru';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'С чего лучше начать?',
          acceptedAnswer: { '@type': 'Answer', text: 'Со стартовой встречи. Это спокойный первый шаг, на котором мы разберём вашу ситуацию и подберём формат.' },
        },
        {
          '@type': 'Question',
          name: 'Нужна ли стартовая встреча перед курсом?',
          acceptedAnswer: { '@type': 'Answer', text: 'Рекомендую — она помогает мне понять ваш этап и задачу, а вам — почувствовать формат работы.' },
        },
        {
          '@type': 'Question',
          name: 'Можно ли заниматься онлайн?',
          acceptedAnswer: { '@type': 'Answer', text: 'Да. Все форматы доступны онлайн без потери в качестве работы.' },
        },
        {
          '@type': 'Question',
          name: 'Подходит ли формат после кесарева?',
          acceptedAnswer: { '@type': 'Answer', text: 'Да, программа адаптируется под ваш этап восстановления и самочувствие.' },
        },
        {
          '@type': 'Question',
          name: 'Как понять, какой формат мне нужен?',
          acceptedAnswer: { '@type': 'Answer', text: 'Именно для этого есть стартовая встреча — она поможет определиться.' },
        },
      ],
    },
    {
      '@type': 'Service',
      name: 'Персональные тренировки — Анастасия Никольская',
      description: 'Персональные тренировки, послеродовое восстановление, мини-группы и онлайн-поддержка.',
      provider: {
        '@type': 'Person',
        name: 'Анастасия Никольская',
        url: `${SITE_URL}/ru/o-trenere/`,
      },
      url: `${SITE_URL}/ru/formaty-i-ceny/`,
      areaServed: [
        { '@type': 'City', name: 'Самара' },
      ],
      offers: [
        {
          '@type': 'Offer',
          name: 'Стартовая встреча',
          price: '3500',
          priceCurrency: 'RUB',
        },
        {
          '@type': 'Offer',
          name: 'Персональное сопровождение — 4 занятия',
          price: '16000',
          priceCurrency: 'RUB',
        },
        {
          '@type': 'Offer',
          name: 'Персональное сопровождение — 8 занятий',
          price: '30000',
          priceCurrency: 'RUB',
        },
        {
          '@type': 'Offer',
          name: 'Персональное сопровождение — 12 занятий',
          price: '44000',
          priceCurrency: 'RUB',
        },
      ],
    },
  ],
};
---

<PageLayout
  lang={lang}
  title="Форматы и стоимость — Анастасия Никольская"
  description="Персональные тренировки, послеродовое восстановление, мини-группы и онлайн-поддержка. Стоимость от 3 500 ₽ за стартовую встречу."
  canonicalPath="/ru/formaty-i-ceny/"
  alternatePath="/en/formats-pricing/"
  structuredData={structuredData}
>
  <Breadcrumb lang={lang} items={[{ label: 'Форматы и цены' }]} />

  <!-- Section 1: Intro -->
  <section class="bg-white">
    <div class="container section">
      <div class="max-w-2xl">
        <h1>Форматы работы и&nbsp;цены</h1>
        <p class="text-lg leading-relaxed mt-6 text-[var(--color-text-body)]">
          Начать можно со&nbsp;стартовой встречи. Она помогает спокойно понять вашу ситуацию, задачи и&nbsp;ограничения, а&nbsp;затем выбрать формат, который подойдёт именно вам.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 2: Featured entry — Starter -->
  <section class="bg-[var(--color-bg-cream)]">
    <div class="container section">
      <div class="card border-l-4 border-l-[var(--color-primary)] p-8 md:p-12">
        <div class="grid grid-cols-1 md:grid-cols-[3fr_2fr] gap-8 items-start">
          <div>
            <h2 class="text-2xl mb-3">Стартовая встреча</h2>
            <p class="text-[16px] leading-relaxed text-[var(--color-text-body)] mb-6">
              Спокойный первый шаг: знакомство, разбор вашей ситуации, целей и&nbsp;ограничений, базовая оценка и&nbsp;понимание, как двигаться дальше.
            </p>
            <ul class="space-y-2">
              {[
                'Знакомство и разбор вашей ситуации',
                'Понимание этапа и задач',
                'Обсуждение ограничений и самочувствия',
                'Ориентир по дальнейшей работе',
                'Выбор подходящего формата',
              ].map(item => (
                <li class="flex items-start gap-2.5">
                  <span class="w-1.5 h-1.5 mt-2 rounded-full bg-[var(--color-primary)] shrink-0" aria-hidden="true"></span>
                  <span class="text-[15px] text-[var(--color-text-body)]">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="flex flex-col items-start md:items-end gap-4">
            <p class="font-[var(--font-heading)] font-bold text-[var(--color-dark)] text-3xl md:text-4xl">от&nbsp;3&nbsp;500&nbsp;₽</p>
            <div>
              <p class="text-[14px] font-medium text-[var(--color-text-body)] mb-2 md:text-right">Выберите способ связи</p>
              <BookingCta lang={lang} label="Записаться на стартовую встречу" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Core — Personal guidance 1:1 -->
  <section class="bg-white">
    <div class="container section">
      <h2 class="mb-3">Персональное сопровождение 1:1</h2>
      <p class="text-[16px] leading-relaxed text-[var(--color-text-body)] mb-10 max-w-2xl">
        Индивидуальная работа под&nbsp;ваш этап, состояние и&nbsp;цели. Подходит для&nbsp;периода беременности, восстановления после&nbsp;родов и&nbsp;мягкого возвращения к&nbsp;активности.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { sessions: '4 занятия', price: 'от 16 000 ₽', note: 'Для начала работы' },
          { sessions: '8 занятий', price: 'от 30 000 ₽', note: 'Основной курс' },
          { sessions: '12 занятий', price: 'от 44 000 ₽', note: 'Углублённая программа' },
        ].map(tier => (
          <div class="card p-6 text-center">
            <p class="text-[14px] text-[var(--color-text-body)]/60 mb-2">{tier.note}</p>
            <p class="font-[var(--font-heading)] font-bold text-[var(--color-dark)] text-2xl mb-1">{tier.price}</p>
            <p class="text-[15px] text-[var(--color-text-body)]">{tier.sessions}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4: Secondary — Mini-group -->
  <section class="bg-[var(--color-bg-cream)]">
    <div class="container section">
      <div class="card p-8">
        <h2 class="text-xl mb-3">Мини-группа</h2>
        <p class="text-[15px] leading-relaxed text-[var(--color-text-body)] mb-3">
          Небольшая группа для&nbsp;тех, кому уже подходит более мягкий формат занятий после понимания своей ситуации и&nbsp;задач.
        </p>
        <p class="text-[14px] text-[var(--color-text-body)]/60">
          Стоимость и&nbsp;набор уточняются отдельно.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 5: Online / Offline -->
  <section class="bg-white">
    <div class="container section">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="mb-6">Онлайн и&nbsp;офлайн</h2>
        <p class="text-[16px] leading-relaxed text-[var(--color-text-body)]">
          Занятия возможны в&nbsp;Самаре и&nbsp;онлайн. Формат определяется исходя из&nbsp;вашей задачи, состояния и&nbsp;удобства.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 6: Mini FAQ -->
  <section class="bg-[var(--color-bg-cream)]">
    <div class="container section">
      <h2 class="text-center mb-10">Частые вопросы</h2>
      <div class="max-w-2xl mx-auto space-y-6">
        {[
          { q: 'С чего лучше начать?', a: 'Со стартовой встречи. Это спокойный первый шаг, на котором мы разберём вашу ситуацию и подберём формат.' },
          { q: 'Нужна ли стартовая встреча перед курсом?', a: 'Рекомендую — она помогает мне понять ваш этап и задачу, а вам — почувствовать формат работы.' },
          { q: 'Можно ли заниматься онлайн?', a: 'Да. Все форматы доступны онлайн без потери в качестве работы.' },
          { q: 'Подходит ли формат после кесарева?', a: 'Да, программа адаптируется под ваш этап восстановления и самочувствие.' },
          { q: 'Как понять, какой формат мне нужен?', a: 'Именно для этого есть стартовая встреча — она поможет определиться.' },
        ].map(item => (
          <details class="group">
            <summary class="flex items-center justify-between cursor-pointer py-3 text-[16px] font-medium text-[var(--color-dark)] hover:text-[var(--color-primary-dark)] transition-colors">
              {item.q}
              <span class="ml-4 shrink-0 text-[var(--color-text-body)]/40 group-open:rotate-45 transition-transform text-xl leading-none" aria-hidden="true">+</span>
            </summary>
            <p class="pb-3 text-[15px] leading-relaxed text-[var(--color-text-body)]">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 7: Helpful reading -->
  <section class="bg-white">
    <div class="container section">
      <div class="max-w-2xl mx-auto text-center">
        <h3 class="text-lg font-semibold mb-4">Полезные материалы</h3>
        <ul class="space-y-2">
          <li><a href="/ru/blog/chto-takoe-startovaya-vstrecha/" class="text-[15px] text-[var(--color-primary-dark)] hover:underline">Что такое стартовая встреча и кому она подходит</a></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section 8: Final CTA -->
  <section class="bg-[var(--color-bg-cream)]">
    <div class="container section">
      <div class="max-w-xl mx-auto text-center">
        <img
          src="/images/pricing-cta.jpg"
          alt="Персональная работа тренера с беременной клиенткой"
          class="w-full max-w-md mx-auto rounded-2xl mb-8"
          width="512"
          height="512"
          loading="lazy"
        />
        <h2 class="mb-6">Начните со&nbsp;стартовой встречи</h2>
        <p class="text-lg leading-relaxed mb-8 text-[var(--color-text-body)]">
          На&nbsp;первой встрече мы спокойно разберём вашу ситуацию и&nbsp;поймём, какой формат подойдёт именно вам.
        </p>
        <BookingCta lang={lang} label="Записаться на стартовую встречу" />
      </div>
    </div>
  </section>
</PageLayout>
