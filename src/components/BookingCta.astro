---
/**
 * BookingCta — now renders a direct-contact icon row.
 * Replaces the former YCLIENTS booking button.
 * Accepts the same props for backward compatibility (they are ignored).
 */
import type { Lang } from '../i18n/utils';
import ContactIcons from './ContactIcons.astro';

interface Props {
  lang: Lang;
  variant?: 'primary' | 'secondary';
  label?: string;
  class?: string;
}

const { lang, class: className } = Astro.props;
---

<div class:list={[className]}>
  <ContactIcons lang={lang} />
</div>
