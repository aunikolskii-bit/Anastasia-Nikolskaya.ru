---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BookingCta from '../../components/BookingCta.astro';
import { SITE_URL } from '../../i18n/utils';

const lang = 'ru';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Анастасия Никольская',
  jobTitle: 'Персональный тренер',
  description: 'Персональный тренер для женщин во время беременности и после родов в Самаре. Узкая специализация, безопасный подход.',
  url: `${SITE_URL}/ru/o-trenere/`,
  image: `${SITE_URL}/images/about-portrait.jpg`,
  knowsAbout: [
    'Тренировки во время беременности',
    'Восстановление после родов',
    'Восстановление после кесарева сечения',
  ],
  areaServed: [
    { '@type': 'City', name: 'Самара' },
  ],
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Диплом о профессиональной переподготовке — Персональный тренер по фитнесу',
      credentialCategory: 'diploma',
      recognizedBy: { '@type': 'Organization', name: 'Академия Федерации бодибилдинга России' },
      dateCreated: '2024-06-30',
    },
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'International Certification — Personal Fitness Trainer',
      credentialCategory: 'certificate',
      recognizedBy: { '@type': 'Organization', name: 'IFBB Academy' },
      dateCreated: '2024-06-30',
    },
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Фитнес для беременных',
      credentialCategory: 'certificate',
      recognizedBy: { '@type': 'Organization', name: 'InstructorPRO' },
      dateCreated: '2025-10-30',
    },
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Функциональный тренинг: матрицы',
      credentialCategory: 'certificate',
      recognizedBy: { '@type': 'Organization', name: 'FitnessStar' },
      dateCreated: '2025-11-08',
    },
  ],
};
---

<PageLayout
  lang={lang}
  title="О тренере — Анастасия Никольская"
  description="Анастасия Никольская — персональный тренер для женщин во время беременности и после родов в Самаре. Узкая специализация, безопасный подход."
  canonicalPath="/ru/o-trenere/"
  alternatePath="/en/about/"
  structuredData={structuredData}
>
  <Breadcrumb lang={lang} items={[{ label: 'О тренере' }]} />

  <!-- Section 1: Intro -->
  <section class="bg-white">
    <div class="container section">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
        <div>
          <p class="label-uppercase mb-4">О специалисте</p>
          <h1>Анастасия Никольская</h1>
          <p class="text-lg leading-relaxed mt-6 mb-6 text-[var(--color-text-body)]">
            Персональный тренер с&nbsp;фокусом на&nbsp;бережную работу с&nbsp;женщинами во&nbsp;время беременности и&nbsp;после родов.
          </p>
          <div class="space-y-4 text-[15px] leading-relaxed text-[var(--color-text-body)]">
            <p>
              Моя задача&nbsp;— не&nbsp;просто дать нагрузку, а&nbsp;помочь вам двигаться спокойно, безопасно и&nbsp;с&nbsp;пониманием того, что подходит именно вашему этапу.
            </p>
            <p>
              Я&nbsp;работаю индивидуально, с&nbsp;учётом срока, самочувствия, ограничений и&nbsp;ваших целей&nbsp;— в&nbsp;Самаре и&nbsp;онлайн.
            </p>
          </div>
          <div class="mt-8">
            <BookingCta lang={lang} label="Записаться на стартовую встречу" />
          </div>
        </div>
        <div>
          <img
            src="/images/about-portrait.jpg"
            alt="Портрет Анастасии Никольской"
            class="rounded-sm w-full h-auto mt-4"
            loading="lazy"
            width="1024"
            height="1536"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: How I work -->
  <section class="bg-[var(--color-bg-cream)]">
    <div class="container section">
      <h2 class="mb-10">Как я&nbsp;работаю</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          {
            title: 'Спокойно, а не через давление',
            text: 'Мне важно, чтобы вам было понятно, безопасно и спокойно на каждом этапе работы.',
          },
          {
            title: 'С учётом вашего состояния',
            text: 'Программа не берётся из общего шаблона — она строится под ваш срок, состояние и задачу.',
          },
          {
            title: 'Без гонки за результатом',
            text: 'Работа строится постепенно. Важен не темп, а правильный и устойчивый путь.',
          },
          {
            title: 'В рамках компетенции тренера',
            text: 'Если есть медицинские вопросы или ограничения, я рекомендую согласовать занятия с врачом.',
          },
        ].map(card => (
          <div class="card p-6">
            <div class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 mt-2.5 rounded-full bg-[var(--color-primary)] shrink-0" aria-hidden="true"></span>
              <div>
                <h3 class="text-[17px] font-semibold text-[var(--color-dark)] mb-2">{card.title}</h3>
                <p class="text-[15px] leading-relaxed text-[var(--color-text-body)]">{card.text}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3: What I help with -->
  <section class="bg-white">
    <div class="container section">
      <div class="max-w-2xl">
        <h2 class="mb-8">С&nbsp;чем я&nbsp;помогаю</h2>
        <ul class="space-y-4">
          {[
            'Безопасно двигаться во время беременности',
            'Мягко возвращаться к активности после родов',
            'Аккуратно входить в работу после кесарева',
            'Лучше чувствовать тело и понимать допустимую нагрузку',
            'Выстраивать спокойный и персональный маршрут вместо случайных упражнений',
          ].map(item => (
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 mt-2.5 rounded-full bg-[var(--color-primary)] shrink-0" aria-hidden="true"></span>
              <span class="text-[16px] leading-relaxed text-[var(--color-text-body)]">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Section 4: Why women trust me -->
  <section class="bg-[var(--color-bg-cream)]">
    <div class="container section">
      <h2 class="mb-10">Почему мне доверяют</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
        {[
          'Дипломированный тренер',
          'Специализация в работе до и после родов',
          'Индивидуальная адаптация вместо шаблонов',
          'Самара и онлайн',
          'Спокойный подход без давления и перегруза',
        ].map(point => (
          <div class="card p-5 flex items-start gap-3">
            <span class="w-1.5 h-1.5 mt-2 rounded-full bg-[var(--color-primary)] shrink-0" aria-hidden="true"></span>
            <span class="text-[15px] leading-relaxed text-[var(--color-dark)]">{point}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 5: Education and certificates -->
  <section id="credentials" class="bg-white">
    <div class="container section">
      <div class="max-w-2xl mb-10">
        <p class="label-uppercase mb-4">Образование и&nbsp;сертификаты</p>
        <h2 class="mb-6">Подтверждённая квалификация</h2>
        <p class="text-[16px] leading-relaxed text-[var(--color-text-body)]">
          Здесь собраны основные документы об&nbsp;образовании и&nbsp;дополнительном обучении, которые подтверждают мою профессиональную подготовку.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          {
            src: '/images/credentials/diploma.jpg',
            w: 800, h: 574,
            title: 'Диплом о профессиональной переподготовке',
            issuer: 'Академия Федерации бодибилдинга России',
            detail: '«Персональный тренер по фитнесу», 280 часов',
            date: '30.06.2024',
          },
          {
            src: '/images/credentials/ifbb.jpg',
            w: 800, h: 1129,
            title: 'Международная сертификация IFBB',
            issuer: 'IFBB Academy',
            detail: 'Personal Fitness Trainer, IFBB-C43170',
            date: '30.06.2024',
          },
          {
            src: '/images/credentials/instructorpro.jpg',
            w: 800, h: 1147,
            title: 'Фитнес для беременных',
            issuer: 'InstructorPRO',
            detail: 'Практический и теоретический курс',
            date: '30.10.2025',
          },
          {
            src: '/images/credentials/matrices.jpg',
            w: 800, h: 1137,
            title: 'Функциональный тренинг: матрицы',
            issuer: 'FitnessStar, Самара',
            detail: 'Структура построения тренировочного процесса',
            date: '08.11.2025',
          },
        ].map(doc => (
          <div class="card p-5">
            <div class="bg-white border border-[var(--color-border)] rounded-lg p-3 mb-4 flex items-center justify-center aspect-[3/4]">
              <img
                src={doc.src}
                alt={doc.title}
                class="max-w-full max-h-full object-contain"
                width={doc.w}
                height={doc.h}
                loading="lazy"
              />
            </div>
            <h3 class="text-[17px] font-semibold text-[var(--color-dark)] mb-1">{doc.title}</h3>
            <p class="text-[15px] text-[var(--color-text-body)] mb-1">{doc.issuer}</p>
            <p class="text-[14px] text-[var(--color-text-body)]/60">{doc.detail} &middot; {doc.date}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 6: Final CTA -->
  <section class="bg-[var(--color-bg-cream)]">
    <div class="container section">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="mb-6">Начните с&nbsp;понятного первого шага</h2>
        <p class="text-lg leading-relaxed mb-8 text-[var(--color-text-body)]">
          На&nbsp;стартовой встрече мы спокойно разберём вашу ситуацию, этап, ограничения и&nbsp;цели и&nbsp;поймём, какой формат подойдёт именно вам.
        </p>
        <BookingCta lang={lang} label="Записаться на стартовую встречу" />
      </div>
    </div>
  </section>
</PageLayout>
