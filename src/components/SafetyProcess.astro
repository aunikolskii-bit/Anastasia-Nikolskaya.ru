---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  lang: Lang;
  asPage?: boolean;
}

const { lang, asPage } = Astro.props;
const Heading = asPage ? 'h1' : 'h2';

const content = {
  ru: {
    label: 'Безопасность',
    title: 'Безопасный подход на каждом этапе',
    points: [
      {
        title: 'Учёт срока и состояния',
        text: 'Каждая программа адаптируется под ваш текущий этап: срок беременности, послеродовый период, самочувствие и ограничения.',
      },
      {
        title: 'Мягкая прогрессия',
        text: 'Нагрузка растёт постепенно и только тогда, когда ваше тело готово. Без резких переходов.',
      },
      {
        title: 'В рамках компетенции тренера',
        text: 'Работа ведётся в области движения и физической подготовки. При наличии медицинских вопросов рекомендуется консультация врача.',
      },
    ],
    note: t(lang, 'medical.note'),
  },
  en: {
    label: 'Safety',
    title: 'A safe approach at every stage',
    points: [
      {
        title: 'Stage and condition awareness',
        text: 'Every plan adapts to your current stage: pregnancy term, postpartum period, how you feel, and any restrictions.',
      },
      {
        title: 'Gentle progression',
        text: 'Load increases gradually and only when your body is ready. No sudden jumps.',
      },
      {
        title: 'Within trainer competence',
        text: 'Work focuses on movement and fitness preparation. For medical concerns, physician consultation is recommended.',
      },
    ],
    note: t(lang, 'medical.note'),
  },
};

const c = content[lang];
---

<section class="bg-white">
  <div class="container section">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
      <div>
        <p class="label-uppercase mb-4">{c.label}</p>
        <Heading class="mb-8">{c.title}</Heading>
        <!-- Reference: 2px structural border wrapping points -->
        <div class="border-2 border-[var(--color-border-strong)]">
          {c.points.map((point, i) => (
            <div class:list={[
              'px-6 py-5',
              i > 0 && 'border-t border-[var(--color-border)]'
            ]}>
              <div class="flex gap-4">
                <div class="shrink-0 w-1 bg-[var(--color-primary)] rounded-full" aria-hidden="true"></div>
                <div>
                  <h3 class="text-lg mb-2">{point.title}</h3>
                  <p class="text-[15px] leading-relaxed">{point.text}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
        <p class="mt-6 text-[13px] text-[var(--color-text-body)]/60 italic">{c.note}</p>
      </div>
      <div class="hidden md:block">
        <img
          src="/images/safety-breathing.jpg"
          alt={lang === 'ru' ? 'Безопасная тренировка — работа с дыханием' : 'Safe training — breathing work'}
          class="w-full h-auto"
          loading="lazy"
          width="1200"
          height="1800"
        />
      </div>
    </div>
  </div>
</section>
