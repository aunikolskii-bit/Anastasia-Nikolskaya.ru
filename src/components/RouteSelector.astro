---
/**
 * RouteSelector — stage selection block with 2 path cards.
 * Each card links directly to the Contacts page.
 */
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  ru: {
    label: 'Тренировки',
    title: 'Какие тренировки вас интересуют?',
    cards: [
      {
        title: 'Во время беременности',
        description: 'Бережная работа с учётом срока, самочувствия и ваших ограничений.',
      },
      {
        title: 'Восстановление после родов',
        description: 'Мягкое восстановление и безопасное возвращение к движению.',
      },
    ],
  },
  en: {
    label: 'Training',
    title: 'Which training path interests you?',
    cards: [
      {
        title: 'During pregnancy',
        description: 'Gentle work adapted to your stage, how you feel, and your current limitations.',
      },
      {
        title: 'Postpartum recovery',
        description: 'Gentle recovery and a safe return to movement.',
      },
    ],
  },
};

const c = content[lang];
const contactUrl = lang === 'ru' ? '/ru/kontakty/' : '/en/contact/';
---

<section class="bg-[var(--color-bg-light)] lg:min-h-[70vh] lg:flex lg:items-center">
  <div class="container section w-full">
    <p class="label-uppercase mb-6">{c.label}</p>
    <h2 class="mb-12">{c.title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl">
      {c.cards.map(card => (
        <a
          href={contactUrl}
          class="card text-left no-underline transition-all duration-200 hover:border-[var(--color-primary)] hover:shadow-[0_5px_25px_rgba(105,70,113,0.15)]"
        >
          <h3 class="text-xl mb-3 font-[var(--font-heading)]">{card.title}</h3>
          <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{card.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
