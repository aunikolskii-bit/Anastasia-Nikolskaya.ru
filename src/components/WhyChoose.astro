---
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  ru: {
    label: 'Почему именно так',
    title: 'Подход, который работает',
    blocks: [
      {
        title: 'Не просто тренировка, а персональный маршрут',
        text: 'Каждая программа строится под ваш этап, состояние и цели, а не по шаблону.',
      },
      {
        title: 'Спокойный и безопасный вход',
        text: 'Без гонки, без давления, без лишней нагрузки. Важно не «быстрее», а правильно.',
      },
      {
        title: 'Поддержка, а не оценка',
        text: 'Здесь не нужно соответствовать чужим ожиданиям. Важно, чтобы вам было спокойно и понятно.',
      },
    ],
  },
  en: {
    label: 'Why this approach',
    title: 'An approach that works',
    blocks: [
      {
        title: 'Not just a workout, but a personal route',
        text: 'Each plan is built around your stage, condition, and goals — not from a generic template.',
      },
      {
        title: 'A calm and safe start',
        text: 'No pressure, no rush, no unnecessary load. The goal is not "faster", but right for you.',
      },
      {
        title: 'Support, not judgement',
        text: 'You do not need to perform for anyone here. You need clarity, safety, and a plan that feels right.',
      },
    ],
  },
};

const c = content[lang];
---

<section id="kak-ya-rabotayu" class="bg-[var(--color-bg-cream)]">
  <div class="container section">
    <div class="grid grid-cols-1 md:grid-cols-[5fr_7fr] gap-10 md:gap-20 items-start">
      <div>
        <p class="label-uppercase mb-6">{c.label}</p>
        <h2>{c.title}</h2>
      </div>
      <!-- Reference: 2px structural border wrapping value props -->
      <div class="border-2 border-[var(--color-border-strong)]">
        {c.blocks.map((block, i) => (
          <div class:list={[
            'px-6 py-7',
            i > 0 && 'border-t border-[var(--color-border)]'
          ]}>
            <span class="label-uppercase !text-[12px] text-[var(--color-text-body)]/40 mb-3 block" aria-hidden="true">0{i + 1}</span>
            <h3 class="text-xl mb-2">{block.title}</h3>
            <p class="text-[15px] leading-relaxed">{block.text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
