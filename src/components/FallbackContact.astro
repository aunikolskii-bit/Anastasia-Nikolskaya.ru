---
import type { Lang } from '../i18n/utils';
import { t, PHONE, PHONE_TEL } from '../i18n/utils';

interface Props {
  lang: Lang;
  class?: string;
}

const { lang, class: className } = Astro.props;
---

<p class:list={['text-[14px] text-[var(--color-text-body)]', className]}>
  {t(lang, 'cta.fallback')}{' '}
  <a href={PHONE_TEL} class="text-[var(--color-primary-dark)] font-semibold hover:underline no-underline">
    {PHONE}
  </a>
</p>
