---
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const items = {
  ru: [
    'Самара + онлайн',
    'Индивидуальный подход под этап и самочувствие',
    'Безопасная прогрессия нагрузки',
  ],
  en: [
    'Samara + online',
    'Personalized to your stage and condition',
    'Safe and gradual load progression',
  ],
};
---

<!-- Reference: strong 2px border framing, centered items -->
<section class="border-y-2 border-[var(--color-border-strong)]">
  <div class="container py-5">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-0 md:divide-x md:divide-[var(--color-border)]">
      {items[lang].map(text => (
        <div class="flex items-center gap-3 md:justify-center md:px-6">
          <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-[var(--color-primary)]" aria-hidden="true"></span>
          <span class="text-[13px] font-semibold text-[var(--color-dark)] tracking-wide uppercase">{text}</span>
        </div>
      ))}
    </div>
  </div>
</section>
