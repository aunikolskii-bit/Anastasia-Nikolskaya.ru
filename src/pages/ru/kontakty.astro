---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import DirectContact from '../../components/DirectContact.astro';
import { SITE_URL, PHONE_TEL } from '../../i18n/utils';

const lang = 'ru';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Анастасия Никольская — персональные тренировки',
  description: 'Персональные тренировки для женщин во время беременности и после родов в Самаре и онлайн.',
  url: SITE_URL,
  telephone: PHONE_TEL.replace('tel:', ''),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Самара',
    addressCountry: 'RU',
  },
  areaServed: [
    { '@type': 'City', name: 'Самара' },
  ],
  availableLanguage: ['ru', 'en'],
  priceRange: 'от 3 500 ₽',
};
---

<PageLayout
  lang={lang}
  title="Контакты — Анастасия Никольская"
  description="Свяжитесь с Анастасией Никольской для записи на тренировки во время беременности и после родов в Самаре."
  canonicalPath="/ru/kontakty/"
  alternatePath="/en/contact/"
  structuredData={structuredData}
>
  <Breadcrumb lang={lang} items={[{ label: 'Контакты' }]} />

  <section class="bg-[var(--color-bg-cream)]">
    <div class="container section">
      <div class="grid grid-cols-1 md:grid-cols-[5fr_7fr] gap-10 md:gap-20 items-start">
        <div>
          <p class="label-uppercase mb-6">Контакты</p>
          <h1 class="mb-6">Свяжитесь со мной</h1>
          <p class="text-lg leading-relaxed max-w-md mb-6">
            Напишите удобным способом — помогу выбрать следующий шаг.
          </p>
          <p class="text-[15px] leading-relaxed text-[var(--color-text-body)] max-w-md">
            После обращения станет понятнее, какой формат подойдёт именно вам.
          </p>
        </div>
        <div>
          <p class="label-uppercase !text-[12px] mb-6">Выберите способ связи</p>
          <DirectContact lang={lang} />
          <div class="mt-10 pt-8 border-t border-[var(--color-border)]">
            <p class="label-uppercase !text-[12px] mb-2">Расположение</p>
            <p class="text-[15px] font-medium text-[var(--color-dark)]">Самара + онлайн</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
