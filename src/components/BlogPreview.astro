---
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  ru: {
    label: 'Блог',
    title: 'Полезные статьи',
    linkText: 'Все статьи',
    linkHref: '/ru/blog/',
    posts: [
      {
        title: 'Тренировки для беременных в Самаре: как выбрать безопасный формат',
        excerpt: 'На что обратить внимание при выборе тренировок во время беременности и почему формат важнее интенсивности.',
        href: '/ru/blog/',
      },
      {
        title: 'Восстановление после родов: с чего начать мягко',
        excerpt: 'Первые шаги к возвращению в активность после родов — без давления и гонки за результатом.',
        href: '/ru/blog/',
      },
    ],
  },
  en: {
    label: 'Blog',
    title: 'Helpful articles',
    linkText: 'All articles',
    linkHref: '/en/blog/',
    posts: [
      {
        title: 'Safe pregnancy training in Samara: how to choose the right format',
        excerpt: 'What to look for when choosing pregnancy workouts and why format matters more than intensity.',
        href: '/en/blog/',
      },
      {
        title: 'Postpartum recovery: how to start gently',
        excerpt: 'First steps back to activity after childbirth — without pressure or rushing for results.',
        href: '/en/blog/',
      },
    ],
  },
};

const c = content[lang];
---

<section class="bg-[var(--color-bg-light)]">
  <div class="container section">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="label-uppercase mb-4">{c.label}</p>
        <h2>{c.title}</h2>
      </div>
      <a href={c.linkHref} class="hidden md:inline-block text-[14px] font-semibold text-[var(--color-primary-dark)] hover:underline no-underline">
        {c.linkText} &rarr;
      </a>
    </div>
    <!-- Reference: 2px bordered cards with shadow -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {c.posts.map(post => (
        <a href={post.href} class="card block hover:border-[var(--color-primary)] transition-colors no-underline group">
          <h3 class="text-lg mb-3 group-hover:text-[var(--color-primary)] transition-colors">{post.title}</h3>
          <p class="text-[15px] leading-relaxed">{post.excerpt}</p>
        </a>
      ))}
    </div>
    <div class="mt-6 md:hidden">
      <a href={c.linkHref} class="text-[14px] font-semibold text-[var(--color-primary-dark)] hover:underline no-underline">
        {c.linkText} &rarr;
      </a>
    </div>
  </div>
</section>
