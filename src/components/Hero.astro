---
/**
 * Hero — two-column: text+CTA left, trainer image right.
 * Trust pills below buttons.
 * Image absorbed from formerly standalone lead image section.
 */
import type { Lang } from '../i18n/utils';
import BookingCta from './BookingCta.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  ru: {
    eyebrow: 'Персональное сопровождение для женщин до и после родов',
    h1: 'Бережное сопровождение до и после родов',
    supporting: 'Спокойная и\u00A0безопасная работа во\u00A0время беременности и\u00A0после родов с\u00A0учётом срока, самочувствия и\u00A0ваших целей\u00A0— в\u00A0Самаре и\u00A0онлайн.',
    ctaPrimary: 'Записаться на стартовую встречу',
    ctaSecondary: 'Как это проходит',
    imgAlt: 'Персональная работа тренера с беременной клиенткой',
    trust: [
      'Индивидуальный подход',
      'До и после родов',
      'Сертифицированный тренер',
    ],
  },
  en: {
    eyebrow: 'Personal guidance before and after childbirth',
    h1: 'Gentle guidance before and after childbirth',
    supporting: 'Calm and safe guidance during pregnancy and after childbirth, tailored to your stage, how you feel, and what you need\u00A0— in Samara and online.',
    ctaPrimary: 'Book an intro session',
    ctaSecondary: 'How it works',
    imgAlt: 'A trainer guiding a pregnant client during a personal session',
    trust: [
      'Individual approach',
      'Prenatal & postpartum',
      'Certified trainer',
    ],
  },
};

const c = content[lang];
---

<section class="bg-[var(--color-bg-cream)]">
  <div class="container pt-12 md:pt-20 pb-0">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
      <!-- Text column -->
      <div class="flex-1 lg:max-w-[50%] py-4 lg:py-12">
        <p class="label-uppercase mb-6">{c.eyebrow}</p>
        <h1 class="mb-8">{c.h1}</h1>
        <p class="text-lg md:text-[19px] text-[var(--color-text-body)] leading-relaxed mb-10 max-w-[520px]">
          {c.supporting}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <BookingCta lang={lang} label={c.ctaPrimary} class="md:py-6 md:px-8" />
          <a
            href="#how-it-works"
            class="btn btn-secondary md:py-6 md:px-8"
          >
            {c.ctaSecondary}
          </a>
        </div>
        <!-- Trust pills -->
        <div class="flex flex-wrap lg:flex-nowrap items-center gap-2">
          {c.trust.map(item => (
            <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-[var(--color-secondary)] rounded-full text-[12px] font-medium text-[var(--color-dark)] whitespace-nowrap shrink-0">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] shrink-0" aria-hidden="true"></span>
              {item}
            </span>
          ))}
        </div>
      </div>
      <!-- Image column -->
      <div class="flex-1 lg:max-w-[50%] w-full">
        <img
          src="/images/hero-guidance.jpg"
          alt={c.imgAlt}
          class="w-full h-auto aspect-[4/5] object-cover object-top rounded-2xl"
          loading="eager"
          width="1024"
          height="1536"
        />
      </div>
    </div>
  </div>
</section>
