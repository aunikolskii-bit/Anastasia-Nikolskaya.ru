---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BookingCta from '../../components/BookingCta.astro';
import { SITE_URL } from '../../i18n/utils';

const lang = 'ru';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Восстановление после родов',
  description: 'Мягкое послеродовое восстановление в Самаре и онлайн. Безопасный возврат к нагрузке после родов и кесарева сечения.',
  provider: {
    '@type': 'Person',
    name: 'Анастасия Никольская',
    url: `${SITE_URL}/ru/o-trenere/`,
  },
  areaServed: [
    { '@type': 'City', name: 'Самара' },
  ],
  serviceType: 'Послеродовое восстановление',
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceLocation: { '@type': 'Place', name: 'Самара' },
    availableLanguage: ['ru', 'en'],
  },
  url: `${SITE_URL}/ru/posle-rodov/`,
};
---

<PageLayout
  lang={lang}
  title="Восстановление после родов в Самаре — Анастасия Никольская"
  description="Мягкое послеродовое восстановление в Самаре и онлайн. Безопасный возврат к нагрузке после родов и кесарева сечения."
  canonicalPath="/ru/posle-rodov/"
  alternatePath="/en/after-childbirth/"
  structuredData={structuredData}
>
  <Breadcrumb lang={lang} items={[{ label: 'После родов' }]} />

  <!-- Photo-light page: all available photos show pregnant clients.
       Using minimal or no imagery to avoid perception mismatch. -->
  <section class="bg-white">
    <div class="container section">
      <div class="max-w-3xl">
        <p class="label-uppercase mb-4">После родов</p>
        <h1>Мягкое возвращение к активности и уверенности в теле</h1>
        <p class="text-lg leading-relaxed mt-6 mb-10">
          После родов тело нуждается в бережном подходе: не в «быстром восстановлении», а в постепенном, безопасном и понятном маршруте. Работа строится с учётом типа родов, срока, самочувствия и ваших целей.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="card">
          <h3 class="text-xl mb-3">Направления работы</h3>
          <ul class="space-y-3 text-[15px] leading-relaxed">
            <li>Корпус, тазовое дно и осанка</li>
            <li>Дыхание и контроль нагрузки</li>
            <li>Постепенный возврат к активности</li>
            <li>Работа после кесарева сечения</li>
            <li>Возвращение уверенности в теле</li>
          </ul>
        </div>
        <div class="card">
          <h3 class="text-xl mb-3">Как начать</h3>
          <ul class="space-y-3 text-[15px] leading-relaxed">
            <li>Стартовая встреча: понимание вашей ситуации</li>
            <li>Индивидуальный план под ваш этап</li>
            <li>Мягкая прогрессия без давления</li>
            <li>Формат: в Самаре или онлайн</li>
          </ul>
        </div>
      </div>

      <p class="text-center mt-8 mb-10 text-[15px] text-[var(--color-text-body)]">
        Подробнее о форматах и стоимости — на странице <a href="/ru/formaty-i-ceny/" class="text-[var(--color-primary-dark)] hover:underline">«Форматы и цены»</a>.
      </p>

      <p class="text-[13px] text-[#707070] italic mb-8 max-w-2xl mx-auto text-center">
        При наличии медицинских противопоказаний рекомендуется консультация врача.
      </p>

      <div class="max-w-2xl mx-auto mb-12">
        <h3 class="text-lg font-semibold mb-4 text-center">Полезные материалы</h3>
        <ul class="space-y-2 text-center">
          <li><a href="/ru/blog/vosstanovlenie-posle-rodov/" class="text-[15px] text-[var(--color-primary-dark)] hover:underline">Восстановление после родов: с чего начать мягко</a></li>
          <li><a href="/ru/blog/trenirovki-posle-kesareva/" class="text-[15px] text-[var(--color-primary-dark)] hover:underline">Возвращение к движению после кесарева</a></li>
          <li><a href="/ru/blog/kogda-nachinat-trenirovki-posle-rodov/" class="text-[15px] text-[var(--color-primary-dark)] hover:underline">Когда можно начинать возвращаться к активности после родов</a></li>
        </ul>
      </div>

      <div class="text-center">
        <BookingCta lang={lang} label="Записаться на стартовую встречу" />
      </div>
    </div>
  </section>
</PageLayout>
