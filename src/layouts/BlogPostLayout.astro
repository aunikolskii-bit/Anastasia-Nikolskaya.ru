---
import type { Lang } from '../i18n/utils';
import PageLayout from './PageLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { t } from '../i18n/utils';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  canonicalPath: string;
  alternatePath: string;
}

const { lang, title, description, pubDate, updatedDate, canonicalPath, alternatePath } = Astro.props;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: {
    '@type': 'Person',
    name: lang === 'ru' ? 'Анастасия Никольская' : 'Anastasia Nikolskaya',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Anastasia Nikolskaya',
    url: 'https://anastasia-nikolskaya.ru',
  },
};

const formattedDate = pubDate.toLocaleDateString(lang === 'ru' ? 'ru-RU' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<PageLayout
  lang={lang}
  title={`${title} — ${lang === 'ru' ? 'Анастасия Никольская' : 'Anastasia Nikolskaya'}`}
  description={description}
  canonicalPath={canonicalPath}
  alternatePath={alternatePath}
  structuredData={structuredData}
>
  <Breadcrumb lang={lang} items={[
    { label: t(lang, 'nav.blog'), href: `/${lang}/blog/` },
    { label: title },
  ]} />

  <article class="bg-white">
    <div class="container section">
      <div class="max-w-3xl">
        <p class="label-uppercase mb-4">{t(lang, 'nav.blog')}</p>
        <h1>{title}</h1>
        <p class="text-sm text-[var(--color-text-body)] mt-3">
          {formattedDate}
          {updatedDate && (
            <span>
              {' '}· {lang === 'ru' ? 'обновлено' : 'updated'}{' '}
              {updatedDate.toLocaleDateString(lang === 'ru' ? 'ru-RU' : 'en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </span>
          )}
        </p>

        <div class="mt-10 prose prose-lg max-w-none
          [&_h2]:text-xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4
          [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
          [&_p]:text-[15px] [&_p]:leading-relaxed [&_p]:text-[var(--color-text-body)] [&_p]:mb-4
          [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mb-4 [&_ul]:text-[15px] [&_ul]:text-[var(--color-text-body)]
          [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:mb-4 [&_ol]:text-[15px] [&_ol]:text-[var(--color-text-body)]
          [&_li]:mb-2
          [&_a]:text-[var(--color-primary-dark)] [&_a]:underline
          [&_strong]:text-[var(--color-dark)]
          [&_blockquote]:border-l-4 [&_blockquote]:border-[var(--color-primary)] [&_blockquote]:pl-4 [&_blockquote]:italic
        ">
          <slot />
        </div>

        <div class="mt-12 pt-8 border-t border-[var(--color-border)]">
          <a href={`/${lang}/blog/`} class="text-[var(--color-primary-dark)] font-semibold hover:underline">
            &larr; {lang === 'ru' ? 'Все статьи' : 'All articles'}
          </a>
        </div>
      </div>
    </div>
  </article>
</PageLayout>
