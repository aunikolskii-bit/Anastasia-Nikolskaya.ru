---
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  ru: {
    label: 'Как это работает',
    title: 'Три шага к началу',
    steps: [
      { number: '01', title: 'Стартовая встреча', text: 'Стартовая встреча и понимание вашей ситуации' },
      { number: '02', title: 'Персональный план', text: 'Персональный план под ваш этап, самочувствие и формат' },
      { number: '03', title: 'Спокойная работа', text: 'Спокойная работа с мягкой прогрессией и понятной следующей точкой' },
    ],
  },
  en: {
    label: 'How it works',
    title: 'Three steps to start',
    steps: [
      { number: '01', title: 'Starter assessment', text: 'Starter assessment and a clear understanding of your current situation' },
      { number: '02', title: 'Personal plan', text: 'A personal plan built around your stage, condition, and preferred format' },
      { number: '03', title: 'Calm work', text: 'Calm work with gentle progression and a clear next step' },
    ],
  },
};

const c = content[lang];
---

<section class="bg-white">
  <div class="container section">
    <div class="grid grid-cols-1 md:grid-cols-[5fr_7fr] gap-10 md:gap-20 items-start">
      <div>
        <p class="label-uppercase mb-6">{c.label}</p>
        <h2>{c.title}</h2>
      </div>
      <!-- Reference: 2px structural border wrapping steps -->
      <div class="border-2 border-[var(--color-border-strong)]">
        {c.steps.map((step, i) => (
          <div class:list={[
            'px-6 py-6',
            i > 0 && 'border-t border-[var(--color-border)]'
          ]}>
            <div class="grid grid-cols-[40px_1fr] gap-4 items-start">
              <span class="text-[14px] font-semibold text-[var(--color-primary-dark)] font-[var(--font-body)] pt-1" aria-hidden="true">
                {step.number}
              </span>
              <div>
                <h3 class="text-xl mb-2">{step.title}</h3>
                <p class="text-[15px] leading-relaxed">{step.text}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
