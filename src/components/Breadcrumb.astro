---
import type { Lang } from '../i18n/utils';
import { t, SITE_URL } from '../i18n/utils';

interface Props {
  lang: Lang;
  items: { label: string; href?: string }[];
}

const { lang, items } = Astro.props;
const homeLabel = t(lang, 'nav.home');
const homeHref = `/${lang}/`;

/* BreadcrumbList JSON-LD */
const breadcrumbItems = [
  { name: homeLabel, url: `${SITE_URL}${homeHref}` },
  ...items.map(item => ({
    name: item.label,
    ...(item.href ? { url: `${SITE_URL}${item.href}` } : {}),
  })),
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    ...(item.url ? { item: item.url } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="container py-1.5">
  <ol class="flex flex-wrap items-center gap-1.5 text-[13px] text-[var(--color-text-body)]/60">
    <li>
      <a href={homeHref} class="hover:text-[var(--color-primary)] transition-colors no-underline py-2 min-h-[44px] inline-flex items-center">{homeLabel}</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        <span aria-hidden="true">/</span>
        {item.href && i < items.length - 1 ? (
          <a href={item.href} class="hover:text-[var(--color-primary)] transition-colors no-underline py-2 min-h-[44px] inline-flex items-center">{item.label}</a>
        ) : (
          <span class="text-[var(--color-dark)]">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
