---
import type { Lang } from '../i18n/utils';
import { SITE_URL } from '../i18n/utils';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  canonicalPath: string;
  alternatePath: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  structuredData?: Record<string, unknown>;
}

const {
  lang,
  title,
  description,
  canonicalPath,
  alternatePath,
  ogImage = '/images/og/og-default.jpg',
  ogType = 'website',
  noindex = false,
  structuredData,
} = Astro.props;

const alternateLang = lang === 'ru' ? 'en' : 'ru';
const canonicalUrl = `${SITE_URL}${canonicalPath}`;
const alternateUrl = `${SITE_URL}${alternatePath}`;
const ogImageUrl = `${SITE_URL}${ogImage}`;
const locale = lang === 'ru' ? 'ru_RU' : 'en_US';
---

<!-- SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- hreflang -->
<link rel="alternate" hreflang={lang} href={canonicalUrl} />
<link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
<link rel="alternate" hreflang="x-default" href={SITE_URL + '/ru/'} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content={locale} />
<meta property="og:site_name" content="Anastasia Nikolskaya" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- RSS -->
{lang === 'ru' && <link rel="alternate" type="application/rss+xml" title="Блог — Анастасия Никольская" href={`${SITE_URL}/rss.xml`} />}
{lang === 'en' && <link rel="alternate" type="application/rss+xml" title="Blog — Anastasia Nikolskaya" href={`${SITE_URL}/rss-en.xml`} />}

<!-- Structured data -->
{structuredData && (
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
)}
