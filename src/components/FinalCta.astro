---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/utils';
import BookingCta from './BookingCta.astro';
import FallbackContact from './FallbackContact.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  ru: {
    title: 'Начните с безопасного первого шага',
    text: 'Стартовая встреча поможет понять, как двигаться дальше — спокойно и в вашем темпе. Без обязательств.',
  },
  en: {
    title: 'Start with a safe first step',
    text: 'The starter assessment will help you understand how to move forward — calmly and at your own pace. No obligations.',
  },
};

const c = content[lang];
---

<section class="bg-white">
  <div class="container section">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] gap-10 md:gap-16 items-center">
      <div>
        <img
          src="/images/final-cta.jpg"
          alt={lang === 'ru' ? 'Фотография тренировки в заключительном блоке страницы' : 'Training photo in the final call-to-action section'}
          class="w-full h-auto aspect-[3/4] object-cover object-top rounded-2xl"
          loading="lazy"
          width="1024"
          height="1536"
        />
      </div>
      <div>
        <h2 class="mb-8">{c.title}</h2>
        <p class="text-lg leading-relaxed mb-8 max-w-md">{c.text}</p>
        <BookingCta lang={lang} label={t(lang, 'cta.book.starter')} class="md:py-6 md:px-8" />
        <div class="mt-6">
          <FallbackContact lang={lang} />
        </div>
      </div>
    </div>
  </div>
</section>
