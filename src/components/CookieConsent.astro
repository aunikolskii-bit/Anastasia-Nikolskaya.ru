---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div
  id="cookie-consent"
  class="fixed bottom-0 left-0 right-0 z-50 hidden"
  role="dialog"
  aria-label={t(lang, 'consent.title')}
>
  <div class="bg-white/95 backdrop-blur-sm border-t border-[var(--color-border)]/60 shadow-[0_-2px_12px_rgba(0,0,0,0.06)]">
    <div class="container px-4 py-3 md:px-8 md:py-4 flex items-center justify-between gap-3 md:gap-6">
      <p class="text-[13px] md:text-[14px] text-[var(--color-text-body)] leading-snug min-w-0">
        <span class="font-semibold text-[var(--color-dark)]">{t(lang, 'consent.title')}.</span>{' '}
        {t(lang, 'consent.text')}
      </p>
      <div class="flex gap-2 shrink-0">
        <button
          id="consent-accept"
          class="text-[13px] font-medium px-4 py-1.5 rounded-full bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-dark)] transition-colors"
        >
          {t(lang, 'consent.accept')}
        </button>
        <button
          id="consent-decline"
          class="text-[13px] font-medium px-4 py-1.5 rounded-full border border-[var(--color-border)] text-[var(--color-text-body)] hover:border-[var(--color-primary-dark)] hover:text-[var(--color-primary-dark)] transition-colors"
        >
          {t(lang, 'consent.decline')}
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const CONSENT_KEY = 'analytics_consent';
  const banner = document.getElementById('cookie-consent');
  const acceptBtn = document.getElementById('consent-accept');
  const declineBtn = document.getElementById('consent-decline');

  function getConsent(): string | null {
    return localStorage.getItem(CONSENT_KEY);
  }

  function setConsent(value: 'accepted' | 'declined') {
    localStorage.setItem(CONSENT_KEY, value);
    banner?.classList.add('hidden');
    if (value === 'accepted') {
      window.dispatchEvent(new CustomEvent('analytics-consent-granted'));
    }
  }

  function showBanner() {
    banner?.classList.remove('hidden');
  }

  // Show banner if no choice saved
  const consent = getConsent();
  if (!consent) {
    showBanner();
  } else if (consent === 'accepted') {
    window.dispatchEvent(new CustomEvent('analytics-consent-granted'));
  }

  acceptBtn?.addEventListener('click', () => setConsent('accepted'));
  declineBtn?.addEventListener('click', () => setConsent('declined'));

  // Cookie settings link (in footer) can re-open the banner
  window.addEventListener('reopen-consent', () => {
    localStorage.removeItem(CONSENT_KEY);
    showBanner();
  });
</script>
