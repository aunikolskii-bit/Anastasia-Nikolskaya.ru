---
/**
 * RouteSelector — static shell with 3 path cards.
 * Interactive version (RouteSelectorIsland) handles the CTA logic.
 */
import type { Lang } from '../i18n/utils';
import RouteSelectorIsland from './RouteSelectorIsland';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  ru: {
    label: 'Ваш маршрут',
    title: 'Выберите, с чего вам начать',
    cards: [
      {
        id: 'pregnancy',
        title: 'Во время беременности',
        description: 'Безопасная работа с учётом срока, самочувствия и уровня подготовки.',
      },
      {
        id: 'postpartum',
        title: 'После родов',
        description: 'Мягкое восстановление, возвращение уверенности в теле и безопасный вход в нагрузку.',
      },
      {
        id: 'unsure',
        title: 'Не уверена, с чего начать',
        description: 'Помогу спокойно понять, какой формат подойдёт именно вам.',
      },
    ],
  },
  en: {
    label: 'Your path',
    title: 'Choose where to start',
    cards: [
      {
        id: 'pregnancy',
        title: 'During pregnancy',
        description: 'Safe guidance tailored to your stage, how you feel, and your level of preparation.',
      },
      {
        id: 'postpartum',
        title: 'Postpartum',
        description: 'Gentle recovery, renewed confidence in your body, and a safe return to movement.',
      },
      {
        id: 'unsure',
        title: 'Not sure where to start',
        description: 'I will help you calmly understand which format is right for you.',
      },
    ],
  },
};

const c = content[lang];
---

<section class="bg-[var(--color-bg-light)] lg:min-h-[70vh] lg:flex lg:items-center">
  <div class="container section w-full">
    <p class="label-uppercase mb-6">{c.label}</p>
    <h2 class="mb-12">{c.title}</h2>
    <RouteSelectorIsland client:visible lang={lang} cards={c.cards} contactUrl={lang === 'ru' ? '/ru/kontakty/' : '/en/contact/'} />
  </div>
</section>
