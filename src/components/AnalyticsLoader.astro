---
// Yandex.Metrika — loads ONLY after consent is granted.
// Replace XXXXXXXX with the actual Metrika counter ID before launch.
const METRIKA_ID = 'XXXXXXXX';
---

<script define:vars={{ METRIKA_ID }}>
  function loadMetrika() {
    if (document.getElementById('ym-script')) return;

    // Yandex.Metrika init
    (function(m,e,t,r,i,k,a){
      m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
      m[i].l=1*new Date();
      for (var j = 0; j < document.scripts.length; j++) {
        if (document.scripts[j].src === r) { return; }
      }
      k=e.createElement(t);a=e.getElementsByTagName(t)[0];
      k.async=1;k.src=r;k.id='ym-script';a.parentNode.insertBefore(k,a)
    })(window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");

    ym(METRIKA_ID, "init", {
      clickmap: false,
      trackLinks: true,
      accurateTrackBounce: true,
      webvisor: false,
    });
  }

  // Listen for consent
  window.addEventListener('analytics-consent-granted', loadMetrika);
</script>

<!-- No noscript fallback: Metrika must only load after consent. -->
