---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import DirectContact from '../../components/DirectContact.astro';

const lang = 'en';
---

<PageLayout
  lang={lang}
  title="Contact — Anastasia Nikolskaya"
  description="Get in touch with Anastasia Nikolskaya for pregnancy and postpartum training in Samara."
  canonicalPath="/en/contact/"
  alternatePath="/ru/kontakty/"
>
  <Breadcrumb lang={lang} items={[{ label: 'Contact' }]} />

  <section class="bg-[var(--color-bg-cream)]">
    <div class="container section">
      <div class="grid grid-cols-1 md:grid-cols-[5fr_7fr] gap-10 md:gap-20 items-start">
        <div>
          <p class="label-uppercase mb-6">Contact</p>
          <h1 class="mb-6">Get in touch</h1>
          <p class="text-lg leading-relaxed max-w-md mb-6">
            Reach out in whichever way is easiest — I will help you find the right next step.
          </p>
          <p class="text-[15px] leading-relaxed text-[var(--color-text-body)] max-w-md">
            After reaching out, we can figure out which format suits your situation best.
          </p>
        </div>
        <div>
          <p class="label-uppercase !text-[12px] mb-6">Choose a contact method</p>
          <DirectContact lang={lang} />
          <div class="mt-10 pt-8 border-t border-[var(--color-border)]">
            <p class="label-uppercase !text-[12px] mb-2">Location</p>
            <p class="text-[15px] font-medium text-[var(--color-dark)]">Samara + online</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
