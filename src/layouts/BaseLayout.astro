---
import type { Lang } from '../i18n/utils';
import SeoHead from '../components/SeoHead.astro';
import CookieConsent from '../components/CookieConsent.astro';
import AnalyticsLoader from '../components/AnalyticsLoader.astro';
import ExitFeedback from '../components/ExitFeedback.astro';
import '../styles/global.css';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  canonicalPath: string;
  alternatePath: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  structuredData?: Record<string, unknown>;
}

const { lang, title, description, canonicalPath, alternatePath, ogImage, ogType, noindex, structuredData } = Astro.props;

const yandexVerification = import.meta.env.YANDEX_VERIFICATION;
const zenVerification = import.meta.env.ZEN_VERIFICATION;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {yandexVerification && <meta name="yandex-verification" content={yandexVerification} />}
    {zenVerification && <meta name="zen-verification" content={zenVerification} />}

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Preload heading font -->
    <link rel="preload" href="/fonts/lora-700-cyrillic.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/lora-700-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Preload brand wordmark font -->
    <link rel="preload" href="/fonts/gentium-plus-400-cyrillic.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/gentium-plus-400-latin.woff2" as="font" type="font/woff2" crossorigin />

    <SeoHead
      lang={lang}
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      alternatePath={alternatePath}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      structuredData={structuredData}
    />
  </head>
  <body>
    <slot />
    <ExitFeedback lang={lang} />
    <CookieConsent lang={lang} />
    <AnalyticsLoader />
  </body>
</html>
