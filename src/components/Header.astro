---
import type { Lang } from '../i18n/utils';
import { t, getNavItems, getAlternateLangUrl } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const navItems = getNavItems(lang);
const alternateLangUrl = getAlternateLangUrl(Astro.url, lang);
const homeHref = `/${lang}/`;
const ctaLabel = lang === 'ru' ? 'Связаться' : 'Contact';
const ctaHref = lang === 'ru' ? `/${lang}/kontakty/` : `/${lang}/contact/`;

/* Desktop nav items — intentional scoped labels (shorter than mobile).
   Mobile labels continue to come from getNavItems() in i18n/utils.ts.
   Future nav label changes must update both places. */
const prefix = `/${lang}`;
const desktopNavItems = lang === 'ru'
  ? [
      { label: 'Беременность',    href: `${prefix}/beremennost/` },
      { label: 'После родов',     href: `${prefix}/posle-rodov/` },
      { label: 'Услуги и цены',   href: `${prefix}/formaty-i-ceny/` },
      { label: 'О специалисте',   href: `${prefix}/o-trenere/` },
      { label: 'Как я работаю',   href: `${prefix}/bezopasnost-i-podhod/` },
    ]
  : [
      { label: 'Pregnancy',          href: `${prefix}/during-pregnancy/` },
      { label: 'Postpartum',         href: `${prefix}/after-childbirth/` },
      { label: 'Services & Pricing', href: `${prefix}/formats-pricing/` },
      { label: 'About',              href: `${prefix}/about/` },
      { label: 'How I Work',         href: `${prefix}/safety-approach/` },
    ];

/* Active state detection */
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  const norm = (s: string) => s.endsWith('/') ? s.slice(0, -1) : s;
  return norm(currentPath) === norm(href) || norm(currentPath).startsWith(norm(href) + '/');
}
---

<!-- Skip to content -->
<a href="#main-content" class="skip-link">
  {t(lang, 'skip.content')}
</a>

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur-sm border-b border-[var(--color-border)]">
  <div class="container flex items-center justify-between h-16 md:h-20">

    <!-- ═══ Mobile brand (visible < xl) ═══ -->
    <a
      href={homeHref}
      class="xl:hidden font-[var(--font-brand)] text-[var(--color-dark)] text-xl tracking-tight no-underline shrink-0 whitespace-nowrap"
    >
      {t(lang, 'site.name')}
    </a>

    <!-- ═══ Desktop wrapper (visible ≥ xl) ═══ -->
    <div class="hidden xl:flex items-center gap-4 flex-1 justify-between">

      <!-- Brand name (outside contour, left) -->
      <a
        href={homeHref}
        class="font-[var(--font-brand)] text-[var(--color-dark)] text-[22px] tracking-tight no-underline shrink-0 whitespace-nowrap"
      >
        {t(lang, 'site.name')}
      </a>

      <!-- Shared contour (capsule containing nav items + CTA) -->
      <nav
        class="flex items-center gap-1 px-1.5 py-1.5 rounded-full bg-white/80 backdrop-blur-md border border-[var(--color-border)] shadow-[0_1px_3px_rgba(0,0,0,0.04),0_4px_12px_rgba(0,0,0,0.03)]"
        aria-label="Main navigation"
      >
        {desktopNavItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'relative px-3.5 py-2 text-[13px] font-medium rounded-full transition-all duration-200 no-underline whitespace-nowrap',
              isActive(item.href)
                ? 'bg-[var(--color-bg-light)] text-[var(--color-primary-dark)] nav-item-active'
                : 'text-[var(--color-text-body)] hover:text-[var(--color-primary)] hover:bg-[var(--color-bg-light)]/50',
            ]}
            {...(isActive(item.href) ? { 'aria-current': 'page' } : {})}
          >
            {item.label}
          </a>
        ))}

        <!-- Divider -->
        <span class="w-px h-5 bg-[var(--color-border)] mx-1" aria-hidden="true"></span>

        <!-- CTA (inside contour) -->
        <a
          href={ctaHref}
          class="text-[13px] font-semibold bg-[var(--color-primary)] text-[#FAF8F5] px-5 py-2 rounded-full hover:bg-[var(--color-primary-dark)] transition-colors no-underline whitespace-nowrap"
        >
          {ctaLabel}
        </a>
      </nav>

      <!-- Language switcher (outside contour, right) -->
      <a
        href={alternateLangUrl}
        class="text-[13px] font-semibold text-[var(--color-primary-dark)] border border-[var(--color-primary-dark)] px-3 py-1.5 rounded-full hover:bg-[var(--color-primary-dark)] hover:text-white transition-colors no-underline shrink-0"
        aria-label={`Switch to ${lang === 'ru' ? 'English' : 'Russian'}`}
      >
        {t(lang, 'lang.switch')}
      </a>
    </div>

    <!-- Mobile menu button (hamburger only — close lives inside panel) -->
    <button
      id="mobile-menu-toggle"
      class="xl:hidden p-2 min-w-[44px] min-h-[44px] flex items-center justify-center text-[var(--color-dark)]"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>

<!-- ═══ Mobile / tablet side-panel menu ═══ -->
<div
  id="menu-backdrop"
  class="fixed inset-0 z-40 bg-black/30 hidden transition-opacity duration-300 opacity-0 xl:hidden"
  aria-hidden="true"
></div>

<nav
  id="mobile-menu"
  class="fixed top-0 right-0 z-50 h-[100dvh] w-[min(85vw,360px)] bg-white shadow-[-4px_0_20px_rgba(0,0,0,0.08)] translate-x-full transition-transform duration-300 ease-out overflow-y-auto overscroll-contain xl:hidden"
  aria-label="Mobile navigation"
>
  <!-- Panel header -->
  <div class="flex items-center justify-between h-16 md:h-20 px-5 border-b border-[var(--color-border)]">
    <span class="text-[15px] font-semibold text-[var(--color-dark)]">
      {lang === 'ru' ? 'Меню' : 'Menu'}
    </span>
    <button
      id="menu-close-btn"
      class="p-2 min-w-[44px] min-h-[44px] flex items-center justify-center text-[var(--color-dark)]"
      aria-label={lang === 'ru' ? 'Закрыть меню' : 'Close menu'}
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Panel content -->
  <div class="px-5 py-4 flex flex-col gap-0.5">
    <a
      href={ctaHref}
      class="block w-full text-center py-2.5 px-4 text-[15px] font-semibold bg-[var(--color-primary)] text-[#FAF8F5] rounded-lg hover:bg-[var(--color-primary-dark)] transition-colors no-underline mb-2"
    >
      {ctaLabel}
    </a>
    {navItems.map(item => (
      <a
        href={item.href}
        class="block py-2.5 px-2 text-[15px] text-[var(--color-text-body)] hover:text-[var(--color-primary)] hover:bg-[var(--color-bg-light)] rounded-lg transition-colors no-underline"
      >
        {item.label}
      </a>
    ))}
    <div class="pt-3 mt-2 border-t border-[var(--color-border)]">
      <a
        href={alternateLangUrl}
        class="inline-block text-[14px] font-semibold text-[var(--color-primary-dark)] border border-[var(--color-primary-dark)] px-4 py-2 rounded-full hover:bg-[var(--color-primary-dark)] hover:text-white transition-colors no-underline"
      >
        {t(lang, 'lang.switch')}
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('menu-backdrop');
  const closeBtn = document.getElementById('menu-close-btn');
  const cookie = document.getElementById('cookie-consent');

  function openMenu() {
    menu?.classList.replace('translate-x-full', 'translate-x-0');
    backdrop?.classList.remove('hidden');
    requestAnimationFrame(() => backdrop?.classList.replace('opacity-0', 'opacity-100'));
    document.body.classList.add('overflow-hidden');
    document.documentElement.classList.add('overflow-hidden');
    if (cookie) cookie.style.setProperty('display', 'none', 'important');
    toggle?.setAttribute('aria-expanded', 'true');
    closeBtn?.focus();
  }

  function closeMenu() {
    menu?.classList.replace('translate-x-0', 'translate-x-full');
    backdrop?.classList.replace('opacity-100', 'opacity-0');
    document.body.classList.remove('overflow-hidden');
    document.documentElement.classList.remove('overflow-hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.focus();
    setTimeout(() => {
      backdrop?.classList.add('hidden');
      if (cookie) cookie.style.removeProperty('display');
    }, 300);
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('translate-x-full')) {
      closeMenu();
    }
  });
</script>
